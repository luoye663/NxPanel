# NxPanel Docker Compose 环境变量示例
#
# 使用方式：
#   cp .env.example .env
#   编辑 .env 后：docker compose --profile nginx up -d
#                  或 docker compose --profile openresty up -d
#   首次登录入口随机生成；如忘记路径：docker logs nxpanel 2>&1 | grep login_path

# Agent 认证密钥（必须修改为强随机字符串；api 与 agent 共享）
# 生成示例：openssl rand -hex 32
NXPANEL_AGENT_TOKEN=change-me-to-a-strong-random-string

# 镜像仓库与 tag
#   GHCR（推荐，公仓免费）：    ghcr.io/luoye663/nxpanel
#   Docker Hub：                docker.io/luoye663/nxpanel
#   本地构建：                  nxpanel
IMAGE_NS=ghcr.io/luoye663/nxpanel
IMAGE_TAG=latest

# 宿主机端口映射（默认 bridge 模式生效；host 网络模式下会被忽略）
PANEL_PORT=18888
HTTP_PORT=80
HTTPS_PORT=443

# 日志级别：debug / info / warn / error
NXPANEL_LOG_LEVEL=info
